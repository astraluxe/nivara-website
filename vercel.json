{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/NIVARA.html" },
    { "source": "/affiliates", "destination": "/affiliates.html" },
    { "source": "/download", "destination": "/download.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
